# App
APP_PORT=8000
DATA_DIR=/data
MAX_UPLOAD_SIZE_MB=20
FILE_CONTEXT_FILE_COUNT=3
MAX_FILE_CONTEXT_CHARS=12000
THREAD_HISTORY_TURNS=6
EMBEDDING_BASE_URL=http://host.docker.internal:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_TIMEOUT_SECONDS=60
FILE_CHUNK_SIZE_CHARS=1200
FILE_CHUNK_OVERLAP_CHARS=200
FILE_VECTOR_TOP_K=6
FILE_VECTOR_CANDIDATE_LIMIT=200
QUERY_REWRITE_COUNT=3
WEB_FUSION_FETCH_PER_QUERY=8
RERANK_BLEND_ALPHA=0.75
RERANK_USE_CROSS_ENCODER=0
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
CROSS_ENCODER_TOP_K=20
CITATION_ALIGN_MIN_SCORE=0.22
SEARCH_MAX_HOPS=2
SEARCH_FOLLOWUP_QUERIES=2
SOURCE_QUALITY_MIN=0.35
CONFIDENCE_ABSTAIN_THRESHOLD=0.42
SEARCH_DEFAULT_MODE=all
TRUST_PREFERRED_DOMAINS=
TRUST_BLOCKED_DOMAINS=
BACKUP_RETENTION_COUNT=10
ASK_CACHE_TTL_SECONDS=300
ASK_CACHE_MAX_ITEMS=300

# Optional auth for personal deployment
AUTH_PASSWORD=
AUTH_COOKIE_NAME=perplexio_session
AUTH_SESSION_MAX_AGE_SECONDS=315360000
AUTH_SESSION_SECRET=
AUTH_COOKIE_SECURE=0

# OCR / transcription (image, audio, video)
OCR_ENABLED=1
# OCR language:
# - "auto" for auto/default model behavior
# - single language: "eng"
# - multi language: "eng+ind" (or "eng,ind")
OCR_LANGUAGE=auto
TRANSCRIPTION_ENABLED=1
TRANSCRIPTION_ENGINE=auto
TRANSCRIPTION_MODEL=base
# Transcription language:
# - "auto" for auto-detection
# - specific language code: "en", "id", etc.
TRANSCRIPTION_LANGUAGE=auto
# Optional for whisper.cpp engine
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL=

# Search (searxng)
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_LANGUAGE=en-US
SEARXNG_SAFESEARCH=0
SEARXNG_RESULT_COUNT=6
SEARXNG_TIMEOUT_SECONDS=20

# OpenAI-compatible LLM
# Examples:
# - OpenAI: https://api.openai.com/v1
# - vLLM:   http://vllm:8000/v1
# - Ollama: http://ollama:11434/v1
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60

# Prompt tuning
SYSTEM_PROMPT=You are a search-grounded assistant. Use only provided web snippets and cite sources like [1], [2].
